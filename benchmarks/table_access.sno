* table_access.sno
* Bottleneck: TABLE creation, integer-key write and read (500 entries).
    T = TABLE(512)
    I = 0
FILL    I = LT(I, 500) I + 1           :F(READ)
    T<I> = I * 2                       :(FILL)
READ    SUM = 0
    I = 0
LOOP    I = LT(I, 500) I + 1           :F(DONE)
    SUM = SUM + T<I>                   :(LOOP)
DONE    OUTPUT = SUM
END
