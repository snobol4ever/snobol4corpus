* eval_fixed.sno
* Bottleneck: EVAL() of a fixed expression — full compile each call.
* 1,000,000 iterations of EVAL('X + 1').
    &TRIM = 1
    &STLIMIT = 1000000000
    T1 = TIME()
    X = 10
    N = 0
LOOP    N = LT(N, 1000000) N + 1       :F(DONE)
    R = EVAL('X + 1')
    :(LOOP)
DONE    T2 = TIME()
    OUTPUT = "result: " R
    OUTPUT = "ms: " (T2 - T1)
END
