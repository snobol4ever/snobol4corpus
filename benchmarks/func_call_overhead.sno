* func_call_overhead.sno
* Bottleneck: function call/return overhead, local var save/restore.
* Trivial INC function called 3000 times.
    DEFINE('INC(N)')                    :(INC_END)
INC     INC = N + 1                    :(RETURN)
INC_END
    R = 0
    N = 0
LOOP    N = LT(N, 3000) N + 1           :F(DONE)
    R = INC(R)                         :(LOOP)
DONE    OUTPUT = R
END
