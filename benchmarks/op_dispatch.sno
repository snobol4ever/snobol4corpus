* op_dispatch.sno
* Bottleneck: arithmetic operator dispatch overhead.
* Mix of +, -, *, / and comparison in a loop.
    N = 1
    OUTER = 0
OUTER   N = N + 3
    N = N - 1
    N = N * 2
    N = GE(N, 10000000) N / 10000      :S(OUTER)F(NEXT)
NEXT    OUTER = LT(OUTER, 100) OUTER + 1     :S(OUTER)
    OUTPUT = N
END
