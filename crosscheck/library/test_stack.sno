*-----------------------------------------------------------------------------------
* test_stack.sno  --  crosscheck tests for library/stack.sno
*
* Expected output:
*   3
*   c
*   b
*   1
*   a
*   0
*   empty ok
*   x
*   1
*   x
*   99
*   world
*   hello
*-----------------------------------------------------------------------------------
-include 'library/stack.sno'

        &TRIM = 1

*       --- basic push/pop/depth ---
        stack_init()
        stack_push('a')
        stack_push('b')
        stack_push('c')
        OUTPUT = stack_depth()          ;* 3
        OUTPUT = stack_pop()            ;* c
        OUTPUT = stack_pop()            ;* b
        OUTPUT = stack_depth()          ;* 1
        OUTPUT = stack_pop()            ;* a
        OUTPUT = stack_depth()          ;* 0

*       --- empty stack FRETURN ---
        stack_pop()                     :S(bad_s1)
        OUTPUT = 'empty ok'             :(s1)
bad_s1  OUTPUT = 'FAIL: empty pop should FRETURN'
s1

*       --- peek does not pop ---
        stack_init()
        stack_push('x')
        OUTPUT = stack_peek()           ;* x
        OUTPUT = stack_depth()          ;* 1
        OUTPUT = stack_pop()            ;* x

*       --- pop into named variable ---
        stack_init()
        stack_push(42)
        stack_push(99)
        stack_pop('myvar')
        OUTPUT = myvar                  ;* 99

*       --- push values from pattern match ---
        stack_init()
        subject = 'hello world'
        subject BREAK(' ') . w1 ' ' REM . w2 =  :F(bad_s2)
        stack_push(w1)
        stack_push(w2)
        OUTPUT = stack_pop()            ;* world
        OUTPUT = stack_pop()            ;* hello
        :(END)
bad_s2  OUTPUT = 'FAIL: pattern match failed'
END
